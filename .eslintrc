{
	"extends": ["plugin:@wordpress/eslint-plugin/recommended"],
	"env": {
		"browser": true,
		"es6": true,
		"node": true
	},
	"globals": {
		"wp": true,
		"wpApiSettings": true,
		"wcSettings": true,
		"es6": true,
		"jQuery": true,
		"cartpdf": true,
		"cartpdfInfoModal": true
	},
	"parser": "@babel/eslint-parser",
	"parserOptions": {
		"ecmaVersion": 8,
		"ecmaFeatures": {
			"modules": true,
			"experimentalObjectRestSpread": true,
			"jsx": true
		}
	}
}
